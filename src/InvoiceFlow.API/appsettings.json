{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "#{SQL_CONNECTION_STRING}#"
  },
  "Jwt": {
    "Secret": "#{JWT_SECRET}#",
    "Issuer": "InvoiceFlow",
    "Audience": "InvoiceFlow-Client",
    "AccessTokenExpiryMinutes": 480,
    "RefreshTokenExpiryDays": 7
  }
}
